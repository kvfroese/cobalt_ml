|  2> %moinp "orb.gbw"
|  3> %pal
|  4> nprocs 10
|  5> end
|  6> %maxcore 4000
|  7> # swap
|  8> %scf
|  9>  Rotate
| 10>   { 28, 26 }
| 11>   { 27, 25 }
| 12>  end
| 13> end
| 14> #
| 15> %rel
| 16>  picturechange 2
| 17> end
| 18> %casscf
| 19>  nel  7
| 20>  norb 5
| 21>  mult 4,2
| 22>  nroots 10,40
| 23>  maxiter 100
| 24>  ActOrbs dOrbs
| 25>  rel
| 26>   printlevel 3
| 27>   dosoc true
| 28>   gtensor true
| 29>   quad true
| 30>  end
| 31> end
