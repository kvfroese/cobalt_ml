NAME = rho.inp
|  1> !CASSCF  DKH DKH-def2-TZVPP  RIJCOSX NoSFitting VeryTightSCF autoaux moread SlowConv
|  2> %moinp "orb.gbw"
|  3> %pal
|  4> nprocs 10
|  5> end
|  6> %maxcore 4000
|  7> # swap
|  8> #%scf
|  9> # Rotate
| 10> #  { 37, 31 }
| 11> # end
| 12> #end
| 13> #
| 14> %rel
| 15>  picturechange 2
| 16> end
| 17> %casscf
| 18>  nel  7
| 19>  norb 5
| 20>  mult 4,2
| 21>  nroots 10,40
| 22>  maxiter 100
| 23>  ActOrbs dOrbs
| 24>  rel
| 25>   printlevel 3
| 26>   dosoc true
| 27>   gtensor true
| 28>   quad true
| 29>  end
| 30> end
| 31> * xyzfile 2 4 geo.xyz *
| 32> 
